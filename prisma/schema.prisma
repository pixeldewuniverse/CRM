generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  staff
}

enum DealStatus {
  lead
  prospect
  deal
  lost
}

enum ActivityType {
  call
  wa
  meeting
}

enum MessageType {
  wa
  email
}

model User {
  id    Int      @id @default(autoincrement())
  name  String
  email String   @unique
  role  UserRole @default(staff)
}

model Customer {
  id         Int        @id @default(autoincrement())
  name       String
  phone      String
  email      String?
  tag        String?
  notes      String?
  created_at DateTime   @default(now())
  deals      Deal[]
  activities Activity[]
  messages   Message[]

  @@index([phone])
  @@index([email])
  @@index([tag])
}

model Deal {
  id          Int        @id @default(autoincrement())
  customer_id Int
  status      DealStatus @default(lead)
  value       Decimal    @db.Decimal(12, 2)
  created_at  DateTime   @default(now())
  customer    Customer   @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([status])
}

model Activity {
  id          Int          @id @default(autoincrement())
  customer_id Int
  type        ActivityType
  note        String
  due_date    DateTime?
  customer    Customer     @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([type])
  @@index([due_date])
}

model Message {
  id          Int         @id @default(autoincrement())
  customer_id Int
  content     String
  type        MessageType
  sent_at     DateTime?
  customer    Customer    @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  @@index([customer_id])
  @@index([type])
  @@index([sent_at])
}
